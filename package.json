{
  "name": "surveyos",
  "version": "0.1.0",
  "private": true,
  "description": "SurveyOS monorepo foundation for a survey operations SaaS platform.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rimraf node_modules .turbo",
    "db:generate": "pnpm --filter @surveyos/db db:generate",
    "db:migrate": "pnpm --filter @surveyos/db db:migrate",
    "db:studio": "pnpm --filter @surveyos/db db:studio",
    "smoke:test": "node scripts/smoke-test.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
