generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Phase 2: Authentication & Organization Management

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            Membership[]
  projects           Project[]
  suppliers          Supplier[]
  projectSuppliers   ProjectSupplier[]
  respondentSessions RespondentSession[]
  callbackEvents     CallbackEvent[]
  projectQuotas      ProjectQuota[]
  auditLogs          AuditLog[]
  fraudSignals       FraudSignal[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     Membership[]
  sessions        Session[]
  createdProjects Project[]    @relation("UserProjects")
  auditLogs       AuditLog[]
}

model Membership {
  id        String   @id @default(uuid())
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Session {
  id        String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 4: Project Management

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  clientName  String
  status      ProjectStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id], onDelete: Restrict)

  integration ProjectIntegration?

  suppliers          ProjectSupplier[]
  respondentSessions RespondentSession[]
  callbackEvents     CallbackEvent[]
  quotas             ProjectQuota[]
  fraudSignals       FraudSignal[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// Phase 5: Project Integration

enum IntegrationStatus {
  WAITING
  TESTING
  LIVE
  FAILED
}

model ProjectIntegration {
  id               String            @id @default(uuid())
  clientSurveyUrl  String?
  status           IntegrationStatus @default(WAITING)
  parameterMapping Json?

  completeCallbackToken  String @unique @default(uuid())
  terminateCallbackToken String @unique @default(uuid())
  quotaFullCallbackToken String @unique @default(uuid())
  securityCallbackToken  String @unique @default(uuid())
  testCallbackToken      String @unique @default(uuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callbackEvents CallbackEvent[]

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// Phase 6: Supplier Management

enum SupplierStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model Supplier {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  status      SupplierStatus @default(ACTIVE)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects           ProjectSupplier[]
  respondentSessions RespondentSession[]
  fraudSignals       FraudSignal[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
  @@index([name])
  @@index([createdAt])
}

// Phase 7: Supplier Project Assignment

enum ProjectSupplierStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model ProjectSupplier {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  status        ProjectSupplierStatus @default(ACTIVE)
  trackingToken String                @unique @default(uuid())
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  respondentSessions RespondentSession[]
  fraudSignals       FraudSignal[]

  @@unique([projectId, supplierId])
  @@index([organizationId])
  @@index([projectId])
  @@index([supplierId])
  @@index([status])
  @@index([trackingToken])
  @@index([createdAt])
}

// Phase 8: Respondent Tracking

enum RespondentSessionStatus {
  STARTED
  REDIRECTED
  COMPLETED
  TERMINATED
  QUOTA_FULL
  SECURITY
  ABANDONED
}

model RespondentSession {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  projectSupplierId String
  projectSupplier   ProjectSupplier @relation(fields: [projectSupplierId], references: [id], onDelete: Cascade)

  sessionToken         String                  @unique @default(uuid())
  supplierRespondentId String?
  status               RespondentSessionStatus @default(STARTED)
  ipAddress            String?
  userAgent            String?
  entryUrl             String?
  redirectUrl          String?
  metadata             Json?

  startedAt    DateTime  @default(now())
  redirectedAt DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callbackEvents CallbackEvent[]
  fraudSignals   FraudSignal[]

  @@index([organizationId])
  @@index([projectId])
  @@index([supplierId])
  @@index([projectSupplierId])
  @@index([sessionToken])
  @@index([status])
  @@index([createdAt])
  @@index([startedAt])
}

// Phase 9: Callback Processing & Quotas

enum CallbackOutcomeType {
  COMPLETE
  TERMINATE
  QUOTA_FULL
  SECURITY
  TEST
}

enum CallbackEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

model CallbackEvent {
  id                   String               @id @default(uuid())
  organizationId       String
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  projectId            String
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  projectIntegrationId String
  projectIntegration   ProjectIntegration   @relation(fields: [projectIntegrationId], references: [id], onDelete: Cascade)
  
  respondentSessionId  String?
  respondentSession    RespondentSession?   @relation(fields: [respondentSessionId], references: [id], onDelete: SetNull)

  outcome              CallbackOutcomeType
  status               CallbackEventStatus  @default(RECEIVED)
  
  sessionToken         String?
  supplierRespondentId String?
  ipAddress            String?
  userAgent            String?
  
  rawQuery             Json?
  rawBody              Json?
  errorMessage         String?
  
  receivedAt           DateTime             @default(now())
  processedAt          DateTime?
  
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([projectIntegrationId])
  @@index([respondentSessionId])
  @@index([sessionToken])
  @@index([outcome])
  @@index([status])
  @@index([receivedAt])
  @@index([createdAt])
}

enum QuotaStatus {
  ACTIVE
  PAUSED
  FULL
  ARCHIVED
}

model ProjectQuota {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name             String
  description      String?
  targetCompletes  Int
  currentCompletes Int          @default(0)
  status           QuotaStatus  @default(ACTIVE)
  criteria         Json?
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([projectId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// Phase 10: Audit Logs & Fraud Signals

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  LOGIN
  LOGOUT
  CALLBACK_RECEIVED
  CALLBACK_PROCESSED
  TRACKING_REDIRECT
  STATUS_CHANGE
  SECURITY_EVENT
}

model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action         AuditActionType
  entityType     String?
  entityId       String?
  message        String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

enum FraudSignalType {
  DUPLICATE_SUPPLIER_RESPONDENT
  DUPLICATE_IP
  RAPID_COMPLETION
  MULTIPLE_OUTCOMES
  SECURITY_CALLBACK
  SUSPICIOUS_USER_AGENT
}

enum FraudSignalSeverity {
  LOW
  MEDIUM
  HIGH
}

enum FraudSignalStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model FraudSignal {
  id                  String               @id @default(uuid())
  
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  projectId           String?
  project             Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  supplierId          String?
  supplier            Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  projectSupplierId   String?
  projectSupplier     ProjectSupplier?     @relation(fields: [projectSupplierId], references: [id], onDelete: SetNull)
  
  respondentSessionId String?
  respondentSession   RespondentSession?   @relation(fields: [respondentSessionId], references: [id], onDelete: SetNull)
  
  type                FraudSignalType
  severity            FraudSignalSeverity  @default(LOW)
  status              FraudSignalStatus    @default(OPEN)
  reason              String?
  metadata            Json?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([supplierId])
  @@index([projectSupplierId])
  @@index([respondentSessionId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}
